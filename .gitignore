env/

# SMPL 授權模型（不得進 git）
data/smpl/
!data/smpl/.gitkeep

# vendor/ 第三方專案（各自獨立 git repo，用 vendor-versions.txt 固定 commit hash）
vendor/

# 本機模型 cache（PHALP / 4D-Humans / detectron2 的 checkpoint 與權重）
/models/

# VRM 模型檔太大且多是使用者自備，不進 git
*.vrm

# 模型權重 / checkpoint
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors
checkpoints/
logs/

# 暫存 / 輸出
tmp/
uploads/
outputs/
*.mp4
*.avi
*.mov
!vendor/**/*.mp4
!vendor/**/example*

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# 環境變數與機密
.env
.env.*
!.env.example
*.pem
*.key
credentials*

